# ─── Dental Clinic System — Environment Variables ─────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Required ────────────────────────────────────────────────────────
# Session secret for express-session. Must be a long random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ─── Optional ────────────────────────────────────────────────────────
# Node environment: "development" | "production"
NODE_ENV=development

# Server ports
PORT=3002
HTTPS_PORT=3443

# CORS allowed origin(s). In development you can leave this unset or use "true".
# In production, set to your frontend URL(s), e.g.:
#   CORS_ORIGIN=https://your-clinic.example.com
#   CORS_ORIGIN=https://a.example.com,https://b.example.com
CORS_ORIGIN=

# PostgreSQL connection string (enables persistence; omit to use in-memory demo mode)
DATABASE_URL=

# Frontend dev server port (used by /api/settings/server-info)
UI_PORT=5175

# ─── Reminder Scheduler ───────────────────────────────────────────────
# Set to "false" to prevent the reminder scheduler from starting on boot.
# Default is enabled. Safe to leave enabled — idempotency prevents duplicate sends.
REMINDER_SCHEDULER_ENABLED=true
